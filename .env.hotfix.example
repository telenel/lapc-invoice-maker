HOTFIX_SSH_HOST="your-vps-host"
HOTFIX_SSH_USER="your-ssh-user"
HOTFIX_SSH_PORT="22"
HOTFIX_REMOTE_PROJECT_DIR="/opt/lapc-invoice-maker"
HOTFIX_APP_URL="https://laportal.montalvo.io/api/version"

# Optional: run a focused test command during hotfix preflight.
# Example:
# HOTFIX_TEST_COMMAND="npm test -- src/__tests__/public-quote-view.test.tsx"
HOTFIX_TEST_COMMAND=""

# Secret used by the in-app cron to call /api/sync/prism-pull.
# Generate with: node -e "console.log(require('crypto').randomBytes(36).toString('base64url'))"
CRON_INTERNAL_SECRET="replace-with-a-48-char-random-string"
