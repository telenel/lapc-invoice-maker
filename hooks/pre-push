#!/bin/bash
# Block pushes that have not passed ship-check for the current HEAD.
# Also block pushes to stale or already-reviewed branches unless CR_FIX=1 is set.

set -euo pipefail

remote_name="${1:-origin}"
branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)

# Only check feature branches, not main
if [ "$branch" = "main" ] || [ -z "$branch" ]; then
  exit 0
fi

git_dir=$(git rev-parse --git-dir)
head_sha=$(git rev-parse HEAD)
ship_check_file="$git_dir/laportal/ship-check.env"

if [ ! -f "$ship_check_file" ]; then
  echo ""
  echo "BLOCKED: No ship-check stamp found for this repo."
  echo "Run: npm run ship-check"
  echo ""
  exit 1
fi

# shellcheck disable=SC1090
. "$ship_check_file"
if [ "${SHIP_CHECK_HEAD:-}" != "$head_sha" ]; then
  echo ""
  echo "BLOCKED: ship-check stamp does not match HEAD $head_sha"
  echo "Run: npm run ship-check"
  echo ""
  exit 1
fi

zero_sha="0000000000000000000000000000000000000000"
tracking_ref="refs/remotes/$remote_name/$branch"
tracking_sha=""
push_local_sha=""
push_remote_sha=""

if git show-ref --verify --quiet "$tracking_ref"; then
  tracking_sha=$(git rev-parse "$tracking_ref")
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${local_ref:-}" ] || continue

  if [ "$remote_ref" = "refs/heads/$branch" ]; then
    push_local_sha="$local_sha"
    push_remote_sha="$remote_sha"
    break
  fi
done

if [ -n "$push_remote_sha" ] && [ "$push_remote_sha" != "$zero_sha" ]; then
  if [ -z "$tracking_sha" ]; then
    echo ""
    echo "BLOCKED: remote branch '$remote_name/$branch' exists, but this machine has no fresh tracking ref."
    echo "Run: git fetch $remote_name --prune"
    echo "Then: npm run git:resume-branch -- $branch"
    echo ""
    exit 1
  fi

  if [ "$tracking_sha" != "$push_remote_sha" ]; then
    echo ""
    echo "BLOCKED: local tracking ref for '$remote_name/$branch' is stale."
    echo "Tracked: $tracking_sha"
    echo "Remote:  $push_remote_sha"
    echo "Run: git fetch $remote_name --prune"
    echo "Then: npm run git:resume-branch -- $branch"
    echo ""
    exit 1
  fi

  if ! git merge-base --is-ancestor "$push_remote_sha" "$push_local_sha"; then
    echo ""
    echo "BLOCKED: push is not a fast-forward of '$remote_name/$branch'."
    echo "Review remote changes first so this branch has a single writer and a clean handoff."
    echo "Run: git fetch $remote_name --prune"
    echo "Then: npm run git:resume-branch -- $branch"
    echo ""
    exit 1
  fi
fi

# Skip PR-open check if GitHub CLI is unavailable
if ! command -v gh >/dev/null 2>&1; then
  exit 0
fi

if [ "${CR_FIX:-}" = "1" ]; then
  exit 0
fi

pr_count=$(gh pr list --head "$branch" --state open --json number --jq 'length' 2>/dev/null || printf '0')
[ -n "$pr_count" ] || pr_count=0
case "$pr_count" in
  ''|*[!0-9]*) pr_count=0 ;;
esac

if [ "$pr_count" -gt 0 ]; then
  pr_info=$(gh pr list --head "$branch" --state open --json number,title,isDraft --jq '.[0] | "#\(.number) \(.title)"')
  pr_is_draft=$(gh pr list --head "$branch" --state open --json isDraft --jq '.[0].isDraft')

  if [ "$pr_is_draft" = "true" ]; then
    exit 0
  fi

  echo ""
  echo "BLOCKED: Branch '$branch' has an open PR: $pr_info"
  echo ""
  echo "Ready PRs are finalized review surfaces. Do not push new development work."
  echo "For active work, keep the PR in draft and use: npm run git:checkpoint"
  echo "If fixing follow-up review issues on an existing PR, use: CR_FIX=1 git push"
  echo ""
  exit 1
fi
