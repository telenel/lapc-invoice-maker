#!/bin/bash
# Block pushes to branches that already have an open PR.
# Override with: CR_FIX=1 git push

if [ "$CR_FIX" = "1" ]; then
  exit 0
fi

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

# Only check feature branches, not main
if [ "$branch" = "main" ] || [ -z "$branch" ]; then
  exit 0
fi

# Check for open PR on this branch
pr_count=$(gh pr list --head "$branch" --state open --json number --jq 'length' 2>/dev/null)

if [ "$pr_count" -gt 0 ]; then
  pr_info=$(gh pr list --head "$branch" --state open --json number,title --jq '.[0] | "#\(.number) \(.title)"')
  echo ""
  echo "BLOCKED: Branch '$branch' has an open PR: $pr_info"
  echo ""
  echo "PRs are finalized once created. Do not push new development work."
  echo "If fixing CodeRabbit review issues, use: CR_FIX=1 git push"
  echo ""
  exit 1
fi
