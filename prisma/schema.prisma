generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  passwordHash   String          @map("password_hash")
  name           String
  email          String          @default("")
  role           String          @default("user")
  active         Boolean         @default(true)
  setupComplete  Boolean         @default(false) @map("setup_complete")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  invoices       Invoice[]
  archivedInvoices Invoice[]     @relation("InvoiceArchiver")
  userQuickPicks UserQuickPick[]
  notifications  Notification[]
  events         Event[]
  contacts       Contact[]       @relation("ContactCreator")
  templates      Template[]
  printQuotes    PrintQuote[]
  drafts         UserDraft[]
  preferences    UserPreference[]
  requisitionsCreated          TextbookRequisition[]        @relation("RequisitionCreator")
  requisitionsStatusChanged    TextbookRequisition[]        @relation("RequisitionStatusChanger")
  requisitionNotificationsSent RequisitionNotification[]    @relation("RequisitionNotificationSender")

  @@map("users")
}

model Staff {
  id              String               @id @default(uuid())
  name            String
  title           String
  department      String
  accountCode     String               @map("account_code")
  extension       String               @default("")
  email           String               @default("")
  phone           String               @default("")
  birthMonth      Int?                 @map("birth_month")
  birthDay        Int?                 @map("birth_day")
  approvalChain   Json                 @default("[]") @map("approval_chain")
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  invoices        Invoice[]
  accountNumbers  StaffAccountNumber[]
  signerHistories StaffSignerHistory[] @relation("signerFor")
  signedFor       StaffSignerHistory[] @relation("signsFor")
  templates       Template[]

  @@map("staff")
}

model StaffAccountNumber {
  id          String   @id @default(uuid())
  staffId     String   @map("staff_id")
  accountCode String   @map("account_code")
  description String   @default("")
  lastUsedAt  DateTime @default(now()) @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, accountCode])
  @@map("staff_account_numbers")
}

model Contact {
  id         String    @id @default(uuid())
  name       String
  email      String    @default("")
  phone      String    @default("")
  org        String    @default("")
  department String    @default("")
  title      String    @default("")
  notes      String?
  createdBy  String    @map("created_by")
  creator    User      @relation("ContactCreator", fields: [createdBy], references: [id])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  invoices   Invoice[]

  @@index([createdBy, name])
  @@index([createdBy, email])
  @@map("contacts")
}

model Invoice {
  id                   String        @id @default(uuid())
  invoiceNumber        String?       @unique @map("invoice_number")
  status               InvoiceStatus @default(DRAFT)
  category             String        @default("SUPPLIES")
  date                 DateTime      @db.Date
  createdBy            String        @map("created_by")
  archivedAt           DateTime?     @map("archived_at")
  archivedBy           String?       @map("archived_by")
  staffId              String?       @map("staff_id")
  contactId            String?       @map("contact_id")
  department           String
  accountCode          String        @map("account_code")
  accountNumber        String        @default("") @map("account_number")
  approvalChain        Json          @default("[]") @map("approval_chain")
  totalAmount          Decimal       @default(0) @map("total_amount") @db.Decimal(10, 2)
  notes                String?
  pdfPath              String?       @map("pdf_path")
  pdfMetadata          Json?         @map("pdf_metadata")
  prismcorePath        String?       @map("prismcore_path")
  isRecurring          Boolean       @default(false) @map("is_recurring")
  isRunning            Boolean       @default(false) @map("is_running")
  runningTitle         String?       @map("running_title")
  recurringInterval    String?       @map("recurring_interval")
  nextRecurringDate    DateTime?     @map("next_recurring_date") @db.Date
  recurringEmail       String?       @map("recurring_email")
  type                 DocumentType  @default(INVOICE)
  quoteStatus          QuoteStatus?  @map("quote_status")
  expirationDate       DateTime?     @map("expiration_date") @db.Date
  recipientName        String?       @map("recipient_name")
  recipientEmail       String?       @map("recipient_email")
  recipientOrg         String?       @map("recipient_org")
  quoteNumber          String?       @unique @map("quote_number")
  shareToken           String?       @unique @map("share_token")
  convertedFromQuoteId String?       @unique @map("converted_from_quote_id")
  acceptedAt           DateTime?     @map("accepted_at")
  convertedAt          DateTime?     @map("converted_at")
  isCateringEvent      Boolean       @default(false) @map("is_catering_event")
  cateringDetails      Json?         @map("catering_details")
  marginEnabled        Boolean       @default(false) @map("margin_enabled")
  marginPercent        Decimal?      @map("margin_percent") @db.Decimal(5, 2)
  taxEnabled           Boolean       @default(false) @map("tax_enabled")
  taxRate              Decimal       @default(0.0975) @map("tax_rate") @db.Decimal(5, 4)
  paymentMethod        String?       @map("payment_method")
  paymentAccountNumber String?       @map("payment_account_number")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  creator User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  archiver User?        @relation("InvoiceArchiver", fields: [archivedBy], references: [id], onDelete: SetNull)
  staff   Staff?        @relation(fields: [staffId], references: [id])
  contact Contact?      @relation(fields: [contactId], references: [id])
  items   InvoiceItem[]

  convertedFromQuote Invoice?        @relation("QuoteToInvoice", fields: [convertedFromQuoteId], references: [id])
  convertedToInvoice Invoice?        @relation("QuoteToInvoice")
  revisedFromQuoteId String?         @unique @map("revised_from_quote_id")
  revisedFromQuote   Invoice?        @relation("QuoteRevision", fields: [revisedFromQuoteId], references: [id])
  revisedToQuote     Invoice?        @relation("QuoteRevision")
  quoteViews         QuoteView[]
  followUps          FollowUp[]

  @@index([type, archivedAt])
  @@index([createdBy, archivedAt])
  @@index([archivedBy, archivedAt])
  @@map("invoices")
}

model InvoiceItem {
  id             String   @id @default(uuid())
  invoiceId      String   @map("invoice_id")
  description    String
  quantity       Decimal  @db.Decimal(10, 2)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(10, 2)
  extendedPrice  Decimal  @map("extended_price") @db.Decimal(10, 2)
  sortOrder      Int      @default(0) @map("sort_order")
  sku            String?
  isTaxable      Boolean  @default(true) @map("is_taxable")
  marginOverride Decimal? @map("margin_override") @db.Decimal(5, 2)
  costPrice      Decimal? @map("cost_price") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model QuickPickItem {
  id           String  @id @default(uuid())
  department   String
  description  String
  defaultPrice Decimal @map("default_price") @db.Decimal(10, 2)
  usageCount   Int     @default(0) @map("usage_count")

  @@map("quick_pick_items")
}

enum InvoiceStatus {
  DRAFT
  FINAL
  PENDING_CHARGE
}

enum DocumentType {
  INVOICE
  QUOTE
}

enum QuoteStatus {
  DRAFT
  SENT
  SUBMITTED_EMAIL
  SUBMITTED_MANUAL
  ACCEPTED
  DECLINED
  REVISED
  EXPIRED
}

enum EventType {
  MEETING
  SEMINAR
  VENDOR
  OTHER
}

enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Event {
  id                String      @id @default(uuid())
  title             String
  description       String?
  type              EventType
  date              DateTime    @db.Date
  startTime         String?     @map("start_time")
  endTime           String?     @map("end_time")
  allDay            Boolean     @default(false) @map("all_day")
  location          String?
  color             String
  recurrence        Recurrence?
  recurrenceEnd     DateTime?   @map("recurrence_end") @db.Date
  reminderMinutes   Int?        @map("reminder_minutes")
  reminderSentDates Json        @default("[]") @map("reminder_sent_dates")
  createdBy         String      @map("created_by")
  creator           User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("events")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  label     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model StaffSignerHistory {
  id            String   @id @default(uuid())
  staffId       String   @map("staff_id")
  signerStaffId String   @map("signer_staff_id")
  position      Int      @default(0)
  lastUsedAt    DateTime @default(now()) @map("last_used_at")

  staff  Staff @relation("signerFor", fields: [staffId], references: [id], onDelete: Cascade)
  signer Staff @relation("signsFor", fields: [signerStaffId], references: [id], onDelete: Cascade)

  @@unique([staffId, signerStaffId, position])
  @@map("staff_signer_history")
}

model SavedLineItem {
  id          String   @id @default(uuid())
  description String
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  department  String
  usageCount  Int      @default(0) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([department, description])
  @@map("saved_line_items")
}

model UserQuickPick {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  description String
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  department  String
  usageCount  Int      @default(0) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, department, description])
  @@map("user_quick_picks")
}

model UserDraft {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  routeKey  String   @map("route_key")
  data      Json
  savedAt   DateTime @default(now()) @map("saved_at")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, routeKey])
  @@index([userId, expiresAt])
  @@map("user_drafts")
}

model UserPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preferences")
}

model QuoteView {
  id              String   @id @default(uuid())
  invoiceId       String   @map("invoice_id")
  viewedAt        DateTime @default(now()) @map("viewed_at")
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  referrer        String?
  viewport        String?
  durationSeconds Int?     @map("duration_seconds")
  respondedWith   String?  @map("responded_with")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("quote_views")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String?
  quoteId   String?  @map("quote_id")
  invoiceId String?  @map("invoice_id")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model RateLimitEvent {
  id        String   @id @default(uuid())
  scope     String
  keyHash   String   @map("key_hash")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([scope, keyHash, createdAt])
  @@index([expiresAt])
  @@map("rate_limit_events")
}

model JobRun {
  id            String   @id @default(uuid())
  jobKey        String   @map("job_key")
  schedulerMode String   @default("app") @map("scheduler_mode")
  runner        String?
  status        String
  startedAt     DateTime @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  durationMs    Int?     @map("duration_ms")
  details       Json?

  @@index([jobKey, startedAt])
  @@index([status, startedAt])
  @@map("job_runs")
}

model Template {
  id              String       @id @default(uuid())
  name            String
  type            DocumentType @default(INVOICE)
  staffId         String?      @map("staff_id")
  department      String       @default("")
  category        String       @default("")
  accountCode     String       @default("") @map("account_code")
  marginEnabled   Boolean      @default(false) @map("margin_enabled")
  marginPercent   Decimal?     @map("margin_percent") @db.Decimal(5, 2)
  taxEnabled      Boolean      @default(false) @map("tax_enabled")
  taxRate         Decimal      @default(0.0975) @map("tax_rate") @db.Decimal(5, 4)
  notes           String       @default("")
  isCateringEvent Boolean      @default(false) @map("is_catering_event")
  cateringDetails Json?        @map("catering_details")
  createdBy       String       @map("created_by")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  creator User           @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  staff   Staff?         @relation(fields: [staffId], references: [id], onDelete: SetNull)
  items   TemplateItem[]

  @@map("templates")
}

model TemplateItem {
  id             String   @id @default(uuid())
  templateId     String   @map("template_id")
  description    String
  quantity       Decimal  @db.Decimal(10, 2)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(10, 2)
  sortOrder      Int      @default(0) @map("sort_order")
  isTaxable      Boolean  @default(true) @map("is_taxable")
  costPrice      Decimal? @map("cost_price") @db.Decimal(10, 2)
  marginOverride Decimal? @map("margin_override") @db.Decimal(5, 2)

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_items")
}

model PrintPricingConfig {
  id                               String             @id @default("default")
  shopTitle                        String             @default("Campus Print Shop") @map("shop_title")
  quotePrefix                      String             @default("PSQ") @map("quote_prefix")
  quoteDisclaimer                  String             @default("Final pricing subject to file review and production requirements.") @map("quote_disclaimer")
  taxEnabled                       Boolean            @default(false) @map("tax_enabled")
  taxRateBasisPoints               Int                @default(0) @map("tax_rate_basis_points")
  bwDuplexMultiplierBasisPoints    Int                @default(17000) @map("bw_duplex_multiplier_basis_points")
  colorDuplexMultiplierBasisPoints Int                @default(18500) @map("color_duplex_multiplier_basis_points")
  createdAt                        DateTime           @default(now()) @map("created_at")
  updatedAt                        DateTime           @updatedAt @map("updated_at")
  tiers                            PrintPricingTier[]
  quotes                           PrintQuote[]

  @@map("print_pricing_configs")
}

model PrintPricingTier {
  id             String              @id @default(uuid())
  configId       String              @map("config_id")
  service        PrintPricingService
  variant        String
  label          String
  description    String?
  minQuantity    Int?                @map("min_quantity")
  maxQuantity    Int?                @map("max_quantity")
  unitPriceCents Int                 @map("unit_price_cents")
  sortOrder      Int                 @default(0) @map("sort_order")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  config PrintPricingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId, service, sortOrder])
  @@map("print_pricing_tiers")
}

model PrintQuote {
  id                    String   @id @default(uuid())
  pricingConfigId       String   @map("pricing_config_id")
  quoteNumber           String   @unique @map("quote_number")
  createdBy             String?  @map("created_by")
  requesterName         String   @default("") @map("requester_name")
  requesterEmail        String   @default("") @map("requester_email")
  requesterOrganization String   @default("") @map("requester_organization")
  subtotalCents         Int      @map("subtotal_cents")
  taxCents              Int      @map("tax_cents")
  totalCents            Int      @map("total_cents")
  taxEnabled            Boolean  @default(false) @map("tax_enabled")
  taxRateBasisPoints    Int      @default(0) @map("tax_rate_basis_points")
  disclaimer            String   @default("")
  shopTitle             String   @default("") @map("shop_title")
  pdfPath               String?  @map("pdf_path")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  pricingConfig PrintPricingConfig   @relation(fields: [pricingConfigId], references: [id], onDelete: Restrict)
  creator       User?                @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  lineItems     PrintQuoteLineItem[]

  @@index([createdAt])
  @@map("print_quotes")
}

model PrintQuoteLineItem {
  id             String              @id @default(uuid())
  quoteId        String              @map("quote_id")
  service        PrintPricingService
  variant        String
  description    String
  details        String?
  quantity       Int
  unitPriceCents Int                 @map("unit_price_cents")
  lineTotalCents Int                 @map("line_total_cents")
  metadata       Json?
  sortOrder      Int                 @default(0) @map("sort_order")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  quote PrintQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, sortOrder])
  @@map("print_quote_line_items")
}

enum PrintPricingService {
  COPY
  POSTER
  BINDING
  SCANNING
}

model FollowUp {
  id             String   @id @default(uuid())
  invoiceId      String   @map("invoice_id")
  type           String
  recipientEmail String   @map("recipient_email")
  subject        String
  sentAt         DateTime @default(now()) @map("sent_at")
  metadata       Json?
  seriesId       String?  @map("series_id")
  shareToken     String?  @unique @map("share_token")
  seriesStatus   String?  @map("series_status")
  maxAttempts    Int?     @map("max_attempts")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, sentAt])
  @@index([seriesId])
  @@index([seriesStatus, type])
  @@map("follow_ups")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

enum RequisitionStatus {
  PENDING
  ORDERED
  ON_SHELF
}

enum RequisitionSource {
  FACULTY_FORM
  STAFF_CREATED
}

enum BookBinding {
  HARDCOVER
  PAPERBACK
  LOOSE_LEAF
  DIGITAL
}

enum BookType {
  PHYSICAL
  OER
}

model TextbookRequisition {
  id                    String              @id @default(uuid())
  instructorName        String              @map("instructor_name")
  phone                 String
  email                 String
  employeeId            String?             @map("employee_id")
  department            String
  course                String
  sections              String
  enrollment            Int
  term                  String
  reqYear               Int                 @map("req_year")
  additionalInfo        String?             @map("additional_info")
  staffNotes            String?             @map("staff_notes")
  status                RequisitionStatus   @default(PENDING)
  source                RequisitionSource   @default(FACULTY_FORM)
  createdBy             String?             @map("created_by")
  lastStatusChangedAt   DateTime?           @map("last_status_changed_at")
  lastStatusChangedBy   String?             @map("last_status_changed_by")
  submittedAt           DateTime            @default(now()) @map("submitted_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  archivedAt            DateTime?           @map("archived_at")
  archivedBy            String?             @map("archived_by")

  creator               User?               @relation("RequisitionCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  statusChanger         User?               @relation("RequisitionStatusChanger", fields: [lastStatusChangedBy], references: [id], onDelete: SetNull)
  books                 RequisitionBook[]
  notifications         RequisitionNotification[]

  @@index([status])
  @@index([term, reqYear])
  @@index([submittedAt])
  @@index([employeeId])
  @@map("textbook_requisitions")
}

model RequisitionBook {
  id             String        @id @default(uuid())
  requisitionId  String        @map("requisition_id")
  bookNumber     Int           @map("book_number")
  author         String
  title          String
  isbn           String
  edition        String?
  copyrightYear  String?       @map("copyright_year")
  volume         String?
  publisher      String?
  binding        BookBinding?
  bookType       BookType      @default(PHYSICAL) @map("book_type")
  oerLink        String?       @map("oer_link")

  requisition TextbookRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@unique([requisitionId, bookNumber])
  @@map("requisition_books")
}

model RequisitionNotification {
  id              String   @id @default(uuid())
  requisitionId   String   @map("requisition_id")
  type            String
  recipientEmail  String   @map("recipient_email")
  subject         String
  success         Boolean
  sentBy          String?  @map("sent_by")
  sentAt          DateTime @default(now()) @map("sent_at")
  errorMessage    String?  @map("error_message")

  requisition TextbookRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  sender      User?               @relation("RequisitionNotificationSender", fields: [sentBy], references: [id], onDelete: SetNull)

  @@index([requisitionId, type])
  @@index([requisitionId, sentAt])
  @@map("requisition_notifications")
}
