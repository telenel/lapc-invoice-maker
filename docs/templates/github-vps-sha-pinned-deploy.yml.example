name: Deploy to VPS

on:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  actions: read
  contents: read

concurrency:
  group: deploy-main
  cancel-in-progress: false

jobs:
  deploy:
    runs-on: ubuntu-latest
    env:
      DEPLOY_SSH_PORT: ${{ secrets.DEPLOY_SSH_PORT || '22' }}
      DEPLOY_REMOTE_PROJECT_DIR: ${{ secrets.DEPLOY_REMOTE_PROJECT_DIR || '/opt/your-app' }}
      DEPLOY_VERIFY_ATTEMPTS: 28
      DEPLOY_VERIFY_SLEEP: 15
      DEPLOY_VERIFY_INITIAL_SLEEP: 60
      APP_VERSION_URL: https://your-app.example.com/api/version
    steps:
      - name: Wait for matching CI run
        uses: actions/github-script@v8
        env:
          EXPECTED_SHA: ${{ github.sha }}
        with:
          script: |
            const expectedSha = process.env.EXPECTED_SHA;
            const maxAttempts = 30;
            const waitMs = 10_000;

            for (let attempt = 1; attempt <= maxAttempts; attempt += 1) {
              const { data } = await github.rest.actions.listWorkflowRunsForRepo({
                owner: context.repo.owner,
                repo: context.repo.repo,
                branch: "main",
                event: "push",
                per_page: 20,
              });

              const ciRun = data.workflow_runs.find(
                (run) => run.name === "CI" && run.head_sha === expectedSha,
              );

              if (!ciRun) {
                core.info(`Attempt ${attempt}/${maxAttempts}: waiting for CI run`);
                await new Promise((resolve) => setTimeout(resolve, waitMs));
                continue;
              }

              if (ciRun.status === "completed" && ciRun.conclusion === "success") {
                return;
              }

              if (ciRun.status === "completed") {
                throw new Error(`CI failed for ${expectedSha}: ${ciRun.html_url}`);
              }

              await new Promise((resolve) => setTimeout(resolve, waitMs));
            }

            throw new Error(`Timed out waiting for CI on ${expectedSha}`);

      - name: Configure SSH
        env:
          DEPLOY_SSH_KEY: ${{ secrets.DEPLOY_SSH_KEY }}
        run: |
          install -d -m 700 ~/.ssh
          printf '%s\n' "$DEPLOY_SSH_KEY" > ~/.ssh/id_ed25519
          chmod 600 ~/.ssh/id_ed25519
          ssh-keyscan -p "$DEPLOY_SSH_PORT" "${{ secrets.DEPLOY_SSH_HOST }}" >> ~/.ssh/known_hosts

      - name: Deploy exact SHA
        env:
          EXPECTED_SHA: ${{ github.sha }}
          DEPLOY_SSH_HOST: ${{ secrets.DEPLOY_SSH_HOST }}
          DEPLOY_SSH_USER: ${{ secrets.DEPLOY_SSH_USER }}
        run: |
          quoted_project_dir=$(printf '%q' "$DEPLOY_REMOTE_PROJECT_DIR")
          remote_cmd="cd $quoted_project_dir && DEPLOY_CHANNEL=github-main DEPLOY_ACTOR=github-actions DEPLOY_EXPECTED_SHA=$EXPECTED_SHA ./scripts/deploy-webhook.sh main"
          ssh_target="$DEPLOY_SSH_HOST"
          if [ -n "$DEPLOY_SSH_USER" ]; then
            ssh_target="${DEPLOY_SSH_USER}@${DEPLOY_SSH_HOST}"
          fi
          ssh -p "$DEPLOY_SSH_PORT" -o BatchMode=yes "$ssh_target" "$remote_cmd"

      - name: Verify live SHA
        env:
          EXPECTED_SHA: ${{ github.sha }}
        run: |
          expected_sha="${EXPECTED_SHA::7}"
          sleep "$DEPLOY_VERIFY_INITIAL_SLEEP"
          last_body=""
          for i in $(seq 1 "$DEPLOY_VERIFY_ATTEMPTS"); do
            body=""
            if ! body=$(curl -fsS --connect-timeout 10 --max-time 20 "$APP_VERSION_URL" 2>/dev/null); then
              body=""
            fi
            last_body="$body"
            status=$(printf '%s' "$body" | grep -oE '"status":"[^"]+"' | cut -d'"' -f4 || true)
            deployed_sha=$(printf '%s' "$body" | grep -oE '"buildSha":"[^"]*"' | cut -d'"' -f4 || true)
            echo "Attempt $i/$DEPLOY_VERIFY_ATTEMPTS: status=${status:-unknown} buildSha=${deployed_sha:-missing}"
            if [ "$status" = "ok" ] && [ "$deployed_sha" = "$expected_sha" ]; then
              exit 0
            fi
            sleep "$DEPLOY_VERIFY_SLEEP"
          done
          echo "Last /api/version response: ${last_body:-<empty>}"
          exit 1
