name: Deploy to VPS

on:
  workflow_run:
    workflows: ["CI"]
    types: [completed]
  workflow_dispatch:
    inputs:
      ref:
        description: "Git ref to build and deploy"
        required: false
        default: "main"

permissions:
  contents: read
  packages: write

concurrency:
  group: deploy-main
  cancel-in-progress: false

jobs:
  deploy:
    if: >-
      ${{
        github.event_name == 'workflow_dispatch' ||
        (
          github.event.workflow_run.conclusion == 'success' &&
          github.event.workflow_run.event == 'push' &&
          github.event.workflow_run.head_branch == 'main'
        )
      }}
    runs-on: ubuntu-latest
    env:
      DEPLOY_SSH_PORT: ${{ secrets.DEPLOY_SSH_PORT || '22' }}
      DEPLOY_REMOTE_PROJECT_DIR: ${{ secrets.DEPLOY_REMOTE_PROJECT_DIR || '/opt/your-app' }}
    steps:
      - name: Resolve deploy target
        id: target
        env:
          INPUT_REF: ${{ github.event.inputs.ref }}
          WORKFLOW_HEAD_BRANCH: ${{ github.event.workflow_run.head_branch }}
          WORKFLOW_HEAD_SHA: ${{ github.event.workflow_run.head_sha }}
        run: |
          if [ "$GITHUB_EVENT_NAME" = "workflow_dispatch" ]; then
            ref="${INPUT_REF:-main}"
          else
            ref="$WORKFLOW_HEAD_SHA"
          fi

          {
            echo "checkout_ref=$ref"
            echo "deploy_ref=${INPUT_REF:-${WORKFLOW_HEAD_BRANCH:-main}}"
          } >> "$GITHUB_OUTPUT"

      - uses: actions/checkout@v5
        with:
          ref: ${{ steps.target.outputs.checkout_ref }}

      - name: Compute image metadata
        id: meta
        run: |
          full_sha=$(git rev-parse HEAD)
          short_sha=$(git rev-parse --short=7 HEAD)
          build_time=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
          image="ghcr.io/${GITHUB_REPOSITORY,,}:$full_sha"

          {
            echo "full_sha=$full_sha"
            echo "short_sha=$short_sha"
            echo "build_time=$build_time"
            echo "image=$image"
          } >> "$GITHUB_OUTPUT"

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Build and publish exact image
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          provenance: false
          tags: |
            ${{ steps.meta.outputs.image }}
          cache-from: type=gha
          cache-to: type=gha,mode=max
          build-args: |
            BUILD_SHA=${{ steps.meta.outputs.short_sha }}
            BUILD_TIME=${{ steps.meta.outputs.build_time }}

      - name: Require SSH deploy secrets
        env:
          DEPLOY_SSH_HOST: ${{ secrets.DEPLOY_SSH_HOST }}
          DEPLOY_SSH_KEY: ${{ secrets.DEPLOY_SSH_KEY }}
        run: |
          if [ -z "$DEPLOY_SSH_HOST" ] || [ -z "$DEPLOY_SSH_KEY" ]; then
            echo "::error::DEPLOY_SSH_HOST and DEPLOY_SSH_KEY must be configured for exact-image VPS deploys."
            exit 1
          fi

      - name: Configure SSH
        env:
          DEPLOY_SSH_KEY: ${{ secrets.DEPLOY_SSH_KEY }}
        run: |
          install -d -m 700 ~/.ssh
          printf '%s\n' "$DEPLOY_SSH_KEY" > ~/.ssh/id_ed25519
          chmod 600 ~/.ssh/id_ed25519
          ssh-keyscan -p "$DEPLOY_SSH_PORT" "${{ secrets.DEPLOY_SSH_HOST }}" >> ~/.ssh/known_hosts

      - name: Deploy exact image
        env:
          EXPECTED_SHA: ${{ steps.meta.outputs.full_sha }}
          DEPLOY_IMAGE: ${{ steps.meta.outputs.image }}
          DEPLOY_REF: ${{ steps.target.outputs.deploy_ref }}
          DEPLOY_SSH_HOST: ${{ secrets.DEPLOY_SSH_HOST }}
          DEPLOY_SSH_USER: ${{ secrets.DEPLOY_SSH_USER }}
        run: |
          quoted_project_dir=$(printf '%q' "$DEPLOY_REMOTE_PROJECT_DIR")
          quoted_deploy_ref=$(printf '%q' "$DEPLOY_REF")
          quoted_deploy_image=$(printf '%q' "$DEPLOY_IMAGE")
          remote_cmd="cd $quoted_project_dir && DEPLOY_CHANNEL=github-main DEPLOY_ACTOR=github-actions DEPLOY_EXPECTED_SHA=$EXPECTED_SHA DEPLOY_IMAGE=$quoted_deploy_image ./scripts/deploy-webhook.sh $quoted_deploy_ref"
          ssh_target="$DEPLOY_SSH_HOST"
          if [ -n "$DEPLOY_SSH_USER" ]; then
            ssh_target="${DEPLOY_SSH_USER}@${DEPLOY_SSH_HOST}"
          fi
          ssh -p "$DEPLOY_SSH_PORT" -o BatchMode=yes "$ssh_target" "$remote_cmd"
