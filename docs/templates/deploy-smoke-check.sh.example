#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${DEPLOY_SMOKE_BASE_URL:-https://your-app.example.com}"
CONNECT_TIMEOUT="${DEPLOY_SMOKE_CONNECT_TIMEOUT:-10}"
MAX_TIME="${DEPLOY_SMOKE_MAX_TIME:-20}"
CHECKS="${DEPLOY_SMOKE_CHECKS:-/login|Sign in|login page;/status|ok|status endpoint}"

old_ifs="$IFS"
IFS=';'
for raw_check in $CHECKS; do
  IFS="$old_ifs"

  check=$(printf '%s' "$raw_check" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
  if [ -z "$check" ]; then
    IFS=';'
    continue
  fi

  path=""
  expected=""
  label=""
  IFS='|' read -r path expected label <<EOF
$check
EOF

  IFS="$old_ifs"

  url="$path"
  case "$url" in
    http://*|https://*)
      ;;
    /*)
      url="${BASE_URL%/}$url"
      ;;
    *)
      url="${BASE_URL%/}/$url"
      ;;
  esac

  body=$(curl -fsS --connect-timeout "$CONNECT_TIMEOUT" --max-time "$MAX_TIME" "$url")
  if [ -n "$expected" ] && ! printf '%s' "$body" | grep -Fq "$expected"; then
    echo "Smoke check failed: ${label:-$url}"
    exit 1
  fi
done
IFS="$old_ifs"
